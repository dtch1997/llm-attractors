.venv*/
runs/
__pycache__/
*.pyc
.DS_Store
*.log
# Bulky per-run transcripts + full jsonls live in GCS (see reports/speak.md).
# Keep only the lean lengths.jsonl needed to rebuild the figures.
results/speak/run_*/
results/speak/trajectories.jsonl
results/speak/all_trajectories.jsonl
# Per-model sweeps (results/speak-<slug>/): keep only lean lengths.jsonl.
results/speak-*/run_*/
results/speak-*/trajectories.jsonl
results/speak-*/all_trajectories.jsonl
# Discovery sweep: bulky per-run transcripts + full jsonl live in GCS
# (gs://.../llm-attractors-stimulus-sweep-discovery/). Keep only lean artifacts:
# lengths.jsonl, summary.csv, samples.md.
results/discovery/*/*/run_*/
results/discovery/*/*/trajectories.jsonl
results/discovery/*/*/status.html
results/discovery/*/*/*.progress.json
results/discovery/all.jsonl
# Cross-model panel: bulky transcripts in GCS (llm-attractors-cross-model-basin-consistency/).
results/crossmodel/*/*/run_*/
results/crossmodel/*/*/trajectories.jsonl
results/crossmodel/*/*/status.html
results/crossmodel/*/*/*.progress.json
results/crossmodel/all.jsonl
